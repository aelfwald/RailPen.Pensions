@model RailPen.Pensions.UI.Models.Pensions.PensionDetailsModel

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="~/js/pension-transfers.js" asp-append-version="true"></script>
}

<div class="jumbotron">
    <h1 class="display-4">Hello, <b>@Html.DisplayFor(modelItem => Model.MemberName)</b>!</h1>
    <p class="lead">As of <b>@Html.DisplayFor(modelItem => Model.Today)</b>, the total value of your pension <b>@Html.DisplayFor(modelItem => Model.PensionRef)</b> is: <b>@Html.DisplayFor(modelItem => Model.PensionValue)</b>.</p>
    <hr class="my-4">
    <p>Below you can view and manage your fund investments and available funds.</p>
</div>

<h2 class="display-4">Invested Funds</h2>
<table  class="table table-striped table-bordered table-hover table-sm">
    <thead>
    <tr>
        <th scope="col">Fund Name</th>
        <th scope="col">Risk Level</th>
        <th scope="col" class="text-end">Unit Price</th>
        <th scope="col" class="text-end">Units Held</th>
        <th scope="col" class="text-end">Fund Value</th>
        <th scope="col" class="text-center">Action</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var fund in Model.InvestedFunds)
    {
        <tr>
            <td>@Html.DisplayFor(modelItem => fund.Name)</td>
            <td>@Html.DisplayFor(modelItem => fund.RiskLevel)</td>
            <td class="text-end">@Html.DisplayFor(modelItem => fund.UnitPrice)</td>
            <td class="text-end">@Html.DisplayFor(modelItem => fund.Units)</td>
            <td class="text-end">@Html.DisplayFor(modelItem => fund.Value)</td>
            <td class="text-center">
                <a class="btn btn-primary btn-sm" onclick="editProduct('@Model.PensionRef', @fund.Id)">Transfer</a>
            </td>
        </tr>
    }
    </tbody>
</table>

<h2 class="display-4">Available Funds</h2>
<table class="table table-striped table-bordered table-hover table-sm">
    <thead>
        <tr>
            <th scope="col">Fund Name</th>
            <th scope="col">Risk Level</th>
            <th scope="col" class="text-end">Unit Price</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var fund in Model.AvailableFunds)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => fund.Name)</td>
                <td>@Html.DisplayFor(modelItem => fund.RiskLevel)</td>
                <td class="text-end">@Html.DisplayFor(modelItem => fund.UnitPrice)</td>
            </tr>
        }
    </tbody>
</table>

<div id="modalWrapper">

</div>

<script>
    function editProduct(pensionRef, toFundId) {
        $.ajax({
            url: '/' + pensionRef + '/fund/' + toFundId,
            success: function(data) {
                $('#modalWrapper').html(data);
                $('#modalWrapper .modal').modal('show');
            }
        });
    }
</script>