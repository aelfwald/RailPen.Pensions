@model RailPen.Pensions.UI.Models.Pensions.TransferModel

<div class="modal fade" id="editModal">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">Transfer Fund</h4>
                <button type="button" class="close" onclick="closeModal()" aria-label="Close"><span aria-hidden="true">&times;</span></button>
            </div>
            <div class="modal-body">
                <form id="transferForm" asp-controller="Pensions" asp-action="ProcessTransfer" method="post">
                    @Html.HiddenFor(model => model.PensionRef)
                    @Html.HiddenFor(model => model.FromFundId)
                    @Html.HiddenFor(model => model.FundValue)

                    @Html.LabelFor(model => model.FromFundName)
                    @Html.TextBoxFor(model => model.FromFundName, new { @class = "form-control", @readonly = "readonly" })
                    <br />
                    @Html.LabelFor(model => model.FundValue)
                    @Html.TextBoxFor(model => model.FundValue, "{0:C}", new { @class = "form-control", @readonly = "readonly" })
                    <br />
                    @Html.LabelFor(model => model.ToFundId)
                    @Html.DropDownListFor(model => model.ToFundId, 
                        new SelectList(Model.AvailableFunds, "Id", "Name"), new { @class = "form-control" })
                    @Html.ValidationMessageFor(model => model.ToFundId, "", new { @class = "text-danger" })
                    <br />
                    @Html.LabelFor(model => model.Amount)
                    @Html.TextBoxFor(model => model.Amount, new { @class = "form-control", @type = "number", @step = "0.01", @min = "0.00", @max = Model.FundValue, @onblur = "enforceMinMaxStep(this)" })
                    <br />

                    @Html.ValidationMessageFor(model => model.Amount, "", new { @class = "text-danger" })
                </form>
            </div>      
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" onclick="submitTransfer()">Save</button>
                <button type="button" class="btn btn-secondary" onclick="closeModal()">Close</button>
            </div>
        </div>

        <div id="liveAlertPlaceholder"></div>
    </div>
</div>

